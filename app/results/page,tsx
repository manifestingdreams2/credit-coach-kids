"use client";

import { useRouter, useSearchParams } from "next/navigation";
import { Suspense } from "react";
import { useGameState } from "@/hooks/useGameState";
import { curriculum, getLevelById, getScoreLabel } from "@/lib/creditCurriculum";
import ScoreBadge from "@/components/ScoreBadge";
import ProgressBar from "@/components/ProgressBar";

function ResultsContent() {
  const router = useRouter();
  const params = useSearchParams();
  const levelId = params.get("level");
  const { state, loaded } = useGameState();

  const level = levelId ? getLevelById(levelId) : null;
  const { label, color, emoji: scoreEmoji } = getScoreLabel(state.creditScore);

  const totalLessons = curriculum.reduce(
    (acc, l) => acc + l.lessons.length,
    0
  );
  const completedCount = state.completedLessons.length;

  // Find next unlocked/incomplete lesson
  const nextLesson = (() => {
    for (const lvl of curriculum) {
      if (state.creditScore < lvl.unlockScore) continue;
      const incomplete = lvl.lessons.find(
        (l) => !state.completedLessons.includes(l.id)
      );
      if (incomplete) return { level: lvl, lesson: incomplete };
    }
    return null;
  })();

  if (!loaded) {
    return (
      <div className="min-h-screen flex items-center justify-center">
        <div className="text-4xl animate-float">🏆</div>
      </div>
    );
  }

  return (
    <div className="min-h-screen pb-10 pb-safe">
      {/* Header */}
      <div className="relative px-4 pt-10 pb-6 overflow-hidden text-center"
        style={{ background: level ? `linear-gradient(160deg, ${level.color}25, transparent)` : "linear-gradient(160deg, rgba(30,115,232,0.15), transparent)" }}
      >
        <button
          onClick={() => router.push("/")}
          className="absolute left-4 top-10 flex items-center gap-1.5 text-white/60 hover:text-white text-sm font-bold active:scale-95 transition-transform"
        >
          <svg className="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth={2.5}>
            <path strokeLinecap="round" strokeLinejoin="round" d="M15 19l-7-7 7-7" />
          </svg>
          Home
        </button>

        <div className="pt-8">
          <div className="text-5xl mb-2 animate-bounce-in">
            {level && state.completedLevels.includes(level.id) ? "🏆" : "⭐"}
          </div>
          <h1 className="font-fredoka text-3xl text-white leading-tight">
            {level && state.completedLevels.includes(level.id)
              ? "Level Complete!"
              : "Nice Work!"}
          </h1>
          {level && (
            <p className="text-white/50 text-sm font-semibold mt-1">
              {level.emoji} {level.title}
            </p>
          )}
        </div>
      </div>

      <div className="px-4">
        {/* Score card */}
        <div className="bg-card rounded-3xl p-6 mb-4 border border-white/10 text-center relative overflow-hidden">
          <div
            className="absolute inset-0 pointer-events-none opacity-10"
            style={{ background: `radial-gradient(ellipse at 50% 0%, ${color}, transparent 70%)` }}
          />
          <p className="text-xs font-bold text-white/40 uppercase tracking-widest mb-3">
            Your Credit Score
          </p>
          <div className="flex justify-center mb-2">
            <ScoreBadge score={state.creditScore} size="lg" animated />
          </div>
          <p className="text-sm font-bold text-white/50 mt-2">
            Keep it up to reach the next tier!
          </p>
        </div>

        {/* Stats grid */}
        <div className="grid grid-cols-2 gap-3 mb-4">
          <div className="bg-card rounded-2xl p-4 border border-white/10 text-center">
            <p className="text-2xl mb-1">📚</p>
            <p className="font-fredoka text-3xl text-blue-400">
              {completedCount}
            </p>
            <p className="text-xs font-bold text-white/40 uppercase tracking-wider mt-0.5">
              Lessons Done
            </p>
          </div>
          <div className="bg-card rounded-2xl p-4 border border-white/10 text-center">
            <p className="text-2xl mb-1">🪙</p>
            <p className="font-fredoka text-3xl text-yellow-400">
              {state.totalCoinsEarned}
            </p>
            <p className="text-xs font-bold text-white/40 uppercase tracking-wider mt-0.5">
              Coins Earned
            </p>
          </div>
        </div>

        {/* Overall progress */}
        <div className="bg-card rounded-2xl p-4 mb-4 border border-white/10">
          <div className="flex items-center justify-between mb-2">
            <span className="text-sm font-bold text-white/80">
              Total Progress
            </span>
            <span className="text-xs font-bold text-white/50">
              {completedCount} / {totalLessons}
            </span>
          </div>
          <ProgressBar
            current={completedCount}
            total={totalLessons}
            color="#1e73e8"
            height={12}
            showLabel={false}
            animated
          />
        </div>

        {/* Level lessons summary */}
        {level && (
          <div className="bg-card rounded-2xl p-4 mb-4 border border-white/10">
            <h3 className="font-fredoka text-base text-white mb-3">
              {level.emoji} {level.title} — Lessons
            </h3>
            <div className="flex flex-col gap-2">
              {level.lessons.map((lesson) => {
                const done = state.completedLessons.includes(lesson.id);
                return (
                  <div
                    key={lesson.id}
                    className="flex items-center gap-3 py-1.5"
                  >
                    <span className="text-lg">
                      {done ? "✅" : "⭕"}
                    </span>
                    <div className="flex-1">
                      <p
                        className={`text-sm font-bold ${
                          done ? "text-white" : "text-white/40"
                        }`}
                      >
                        {lesson.emoji} {lesson.term}
                      </p>
                    </div>
                    {done && (
                      <span className="text-xs font-bold text-emerald-400 bg-emerald-400/10 px-2 py-0.5 rounded-full">
                        Done
                      </span>
                    )}
                  </div>
                );
              })}
            </div>
          </div>
        )}

        {/* Score tier progress */}
        <div className="bg-card rounded-2xl p-4 mb-5 border border-white/10">
          <h3 className="font-fredoka text-base text-white mb-3">
            📊 Score Tiers
          </h3>
          {[
            { label: "Very Poor", min: 300, max: 499, color: "#EF4444" },
            { label: "Poor", min: 500, max: 579, color: "#F97316" },
            { label: "Fair", min: 580, max: 669, color: "#F59E0B" },
            { label: "Good", min: 670, max: 739, color: "#84CC16" },
            { label: "Very Good", min: 740, max: 799, color: "#22C55E" },
            { label: "Exceptional", min: 800, max: 850, color: "#10B981" },
          ].map((tier) => {
            const isCurrentTier =
              state.creditScore >= tier.min &&
              state.creditScore <= tier.max;
            return (
              <div key={tier.label} className="flex items-center gap-2.5 mb-1.5">
                <div
                  className="w-2 h-5 rounded-full shrink-0"
                  style={{ background: tier.color }}
                />
                <span
                  className={`text-xs font-bold flex-1 ${
                    isCurrentTier ? "text-white" : "text-white/30"
                  }`}
                >
                  {tier.label}
                </span>
                <span
                  className={`text-xs font-semibold ${
                    isCurrentTier ? "text-white/60" : "text-white/20"
                  }`}
                >
                  {tier.min}–{tier.max}
                </span>
                {isCurrentTier && (
                  <span
                    className="text-xs font-black px-2 py-0.5 rounded-full"
                    style={{
                      background: `${tier.color}25`,
                      color: tier.color,
                    }}
                  >
                    You ← 
                  </span>
                )}
              </div>
            );
          })}
        </div>

        {/* CTA */}
        <div className="flex flex-col gap-3">
          {nextLesson ? (
            <button
              onClick={() => router.push(`/lesson/${nextLesson.lesson.id}`)}
              className="w-full py-4 rounded-2xl font-fredoka text-lg text-white shadow-lg hover:brightness-110 active:scale-95 transition-all"
              style={{
                background: `linear-gradient(135deg, ${nextLesson.level.color}, ${nextLesson.level.color}cc)`,
                boxShadow: `0 8px 24px ${nextLesson.level.color}40`,
              }}
            >
              Next: {nextLesson.lesson.emoji} {nextLesson.lesson.term} →
            </button>
          ) : (
            <div className="w-full py-4 rounded-2xl text-center font-fredoka text-lg text-yellow-400 border border-yellow-400/30 bg-yellow-400/10">
              🏆 You've completed all available lessons!
            </div>
          )}

          <button
            onClick={() => router.push("/")}
            className="w-full py-3 rounded-2xl font-bold text-sm text-white/60 bg-white/5 border border-white/10 hover:bg-white/10 active:scale-95 transition-all"
          >
            Back to Home
          </button>
        </div>
      </div>
    </div>
  );
}

export default function ResultsPage() {
  return (
    <Suspense
      fallback={
        <div className="min-h-screen flex items-center justify-center">
          <div className="text-4xl animate-float">🏆</div>
        </div>
      }
    >
      <ResultsContent />
    </Suspense>
  );
}